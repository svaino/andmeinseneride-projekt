# Andmebaas (analüütika — compose.yml teenus "db")
POSTGRES_USER=sinu_kasutaja
POSTGRES_PASSWORD=sinu_parool
POSTGRES_DB=andmebaas
DB_PORT_HOST=5432

# Airflow (compose.yml)
AIRFLOW_UID=50000
AIRFLOW_USER=airflow
AIRFLOW_PASSWORD=airflow
AIRFLOW_DB=airflow
AIRFLOW_PORT_HOST=8080

# Superset (compose.yml)
SUPERSET_DB_USER=superset
SUPERSET_DB_PASSWORD=superset
SUPERSET_DB_NAME=superset
SUPERSET_SECRET_KEY=change-me-to-a-long-random-string
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=admin
SUPERSET_ADMIN_EMAIL=admin@example.com
SUPERSET_PORT_HOST=8088

# Äriregistri avaandmete API
ARIREGISTER_USER=andmed
ARIREGISTER_PASSWORD=andmetes
ARIREGISTER_API_URL=https://avaandmed.ariregister.rik.ee/api

# Statistikaamet PxWeb API
STAT_API_URL=https://andmed.stat.ee/api/v1/et/stat

# Dbt versioon
_PIP_ADDITIONAL_REQUIREMENTS=dbt-postgres==1.8.2 dbt-core==1.8.2 requests python-dotenv psycopg2-binary beautifulsoup4 pandas sqlalchemy
